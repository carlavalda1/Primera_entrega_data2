import pandas as pd
import requests

def get_worldbank_data(indicator, start_year=2010, end_year=2019):
    records = []

    for year in range(start_year, end_year + 1):
        url = (
            f"https://api.worldbank.org/v2/country/all/"
            f"indicator/{indicator}?date={year}&format=json&per_page=20000"
        )
        response = requests.get(url).json()

        if response and len(response) > 1:
            for item in response[1]:
                records.append({
                    "country": item["country"]["value"],
                    "year": year,
                    "value": item["value"]
                })

    return pd.DataFrame(records)

# Descargar datasets
gdp = get_worldbank_data("NY.GDP.PCAP.CD")
co2 = get_worldbank_data("EN.ATM.CO2E.PC")
energy = get_worldbank_data("EG.USE.PCAP.KG.OE")
