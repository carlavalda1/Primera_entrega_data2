gdp = gdp.rename(columns={"value": "gdp_per_capita"})
co2 = co2.rename(columns={"value": "co2_per_capita"})
energy = energy.rename(columns={"value": "energy_per_capita"})

# Nos quedamos solo con datasets válidos
dfs = [gdp, co2, energy]
dfs = [df for df in dfs if not df.empty]

from functools import reduce

df = reduce(
    lambda left, right: left.merge(right, on=["country", "year"], how="inner"),
    dfs
)

df.dropna(inplace=True)
df.head()
